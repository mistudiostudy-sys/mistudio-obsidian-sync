{
  "name": "mistudio-obsidian-sync",
  "version": "0.8.0",
  "description": "Plugin de Obsidian que sincroniza el contenido de MiStudio al vault (two-way opcional).",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": ["obsidian", "mistudio"],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.20.0",
    "obsidian": "^1.5.7",
    "typescript": "^5.4.0"
  }
}
